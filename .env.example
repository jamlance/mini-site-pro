# --- identity / schema ---
APP_NAME=mini-site-pro

# --- OAuth client (from `node scripts/register-app.mjs`) ---
OAUTH_CLIENT_ID=inkid_xxx
OAUTH_CLIENT_SECRET=xxx

# --- Inkress API ---
# Token-endpoint base for the OAuth grants:
INKRESS_API_BASE=https://api-dev.inkress.com/api/v1
# Which host the admin SDK talks to: live | sandbox
MODE=sandbox

# --- persistence (omit to run with an in-memory session store, no DB) ---
APPS_DATABASE_URL=postgres://user:pass@host:5432/bookerva_apps

# --- webhooks ---
INKRESS_WEBHOOK_SECRET=whsec_xxx

# --- embedding ---
# Who may iframe this app (space-separated). Defaults to the Inkress dashboards.
# FRAME_ANCESTORS=https://dev.inkress.com https://merchant.inkress.com
PUBLIC_BASE_URL=https://mini-site-pro.apps.inkress.com

# --- standalone (non-embedded) OAuth-redirect path; 1 to enable ---
STANDALONE=0

# --- optional AWS providers (email/blob/sms) ---
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_PUBLIC_BASE=
# SES_FROM=hello@example.com
